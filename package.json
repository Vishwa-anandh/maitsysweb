{
  "name": "maitsys",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:test": "tsc -b && vite build --mode test",
    "postbuild": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview",
    "analyze": "npx vite-bundle-visualizer",
    "sonar": "sonar-scanner"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "exclude": [
      "/podcast",
      "/podcast/"
    ],
    "include": [
      "/",
      "/about-us",
      "/careers",
      "/contact-us",
      "/blog",
      "/blog/sap-btp-cost-optimization-strategies",
      "/blog/azure-cost-optimization-finops-cloud-cost-management",
      "/blog/sap-security-best-practices-2026-guide",
      "/blog/sap-ecc-to-s4hana-cloud-migration-roadmap",
      "/blog/sap-basis-automation-cloud",
      "/blog/sap-upgrade-factory-approach-ecc-ehp-s4hana",
      "/blog/sap-s4hana-conversion-system-conversion-guide",
      "/blog/sap-s4hana-cloud-public-edition-implementation-guide",
      "/blog/sap-s4hana-migration",
      "/blog/ai-powered-sap-idoc-monitoring",
      "/blog/sap-ecc-2027-deadline-by-ehp-version",
      "/blog/sap-disaster-recovery-aws-azure-best-practices",
      "/blog/cloud-cost-optimization-aws-azure",
      "/blog/sap-emergency-access-compliance-report",
      "/blog/sap-migration-access-report",
      "/blog/path-to-ai-implementation",
      "/products",
      "/products/sap-idoc-monitoring",
      "/products/mio-user-monitoring",
      "/products/firefighter",
      "/products/cloud-cost-optimizer",
      "/cyber-security-services",
      "/sap-services",
      "/sap-migration-services",
      "/sap-btp-services",
      "/sap-security-grc-services",
      "/aws-managed-services",
      "/azure-managed-services",
      "/microsoft-power-platform",
      "/power-apps",
      "/power-automate",
      "/power-bi",
      "/m365-automation",
      "/privacy-policy",
      "/terms-conditions",
      "/products/sap-idoc-monitoring/privacy-policy",
      "/products/sap-idoc-monitoring/TermsAndConditions",
      "/products/firefighter/privacy-policy",
      "/products/firefighter/terms-and-conditions"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "skipThirdPartyRequests": true,
    "concurrency": 1,
    "async": false,
    "crawl": false
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.7",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-pages": "^0.33.2",
    "vite-plugin-sitemap": "^0.8.2"
  },
  "dependencies": {
    "framer-motion": "^12.23.24",
    "lucide-react": "^1.14.0",
    "motion": "^12.29.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.9.3",
    "react-snap": "^1.13.1",
    "sonar-scanner": "^3.1.0"
  }
}
